rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /* =========================
       HELPERS
    ========================== */

    function loggedIn() {
      return request.auth != null;
    }

    function validString(field) {
      return field is string && field.size() > 0;
    }

    function validNumber(field) {
      return field is number;
    }

    function validList(field) {
      return field is list;
    }

    /* =========================
       USER PROFILES
       Document ID: phone number
       Ownership model: Phone-based (no Auth UID check)
       Current: Any logged-in user can read/write
       Risk: Known — requires Auth UID migration to fix
       Safe hardening: delete locked, field validation on create
    ========================== */

    match /users/{phone} {

      allow read: if loggedIn();

      allow create: if
        loggedIn() &&
        validString(request.resource.data.phone);

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent profile deletion */
      allow delete: if false;
    }

    /* =========================
       CATEGORY SYSTEM
       Admin-managed, safe for public read
    ========================== */

    match /categories/{categoryId} {

      allow read: if true;

      /* Admin managed via Firebase console */
      allow write: if false;

      match /subcategories/{subId} {

        allow read: if true;

        allow write: if false;
      }
    }

    /* =========================
       USER SELECTIONS
       Document ID: auto-generated
       Ownership model: Phone-based (uid field = phone)
       Safe hardening: delete locked, create requires uid
    ========================== */

    match /selections/{docId} {

      allow read: if loggedIn();

      allow create: if
        loggedIn() &&
        validString(request.resource.data.uid) &&
        validString(request.resource.data.phone) &&
        validString(request.resource.data.category);

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent selection tampering/deletion */
      allow delete: if false;
    }

    /* =========================
       GROUP MATCHING
       Document ID: auto-generated
       Ownership model: Phone-based (members[].phone, createdBy)
       Safe hardening: delete locked, create validates structure
    ========================== */

    match /groups/{groupId} {

      allow read: if loggedIn();

      allow create: if
        loggedIn() &&
        validString(request.resource.data.category) &&
        validString(request.resource.data.option) &&
        validNumber(request.resource.data.membersCount) &&
        validNumber(request.resource.data.requiredSize) &&
        validList(request.resource.data.members) &&
        validList(request.resource.data.memberUIDs) &&
        validString(request.resource.data.createdBy) &&
        request.resource.data.membersCount >= 1 &&
        request.resource.data.requiredSize >= 2;

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent group deletion by users */
      allow delete: if false;
    }

    /* =========================
       MATCH REQUESTS
       Document ID: auto-generated
       New collection for admin match tracking
      ========================== */

    match /matchRequests/{docId} {

      allow read: if loggedIn();

      allow create: if
        loggedIn() &&
        request.resource.data.userA is map &&
        request.resource.data.userB is map &&
        validString(request.resource.data.userA.phone) &&
        validString(request.resource.data.userB.phone) &&
        validString(request.resource.data.status);

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent deletion */
      allow delete: if false;
    }

    /* =========================
       PAYMENTS
       Document ID: auto-generated
       Safe hardening: delete locked, update locked, read all (for admin)
       Create requires valid uid + amount
    ========================== */

    match /payments/{paymentId} {

      allow read: if
        loggedIn();

      allow create: if
        loggedIn() &&
        validString(request.resource.data.uid) &&
        validNumber(request.resource.data.amount);

      /* 🔒 SAFE HARDENING: Payments immutable after creation */
      allow update: if false;

      /* 🔒 SAFE HARDENING: Prevent payment deletion */
      allow delete: if false;
    }

    /* =========================
       CHAT SYSTEM
       Document ID: auto-generated
       Safe hardening: delete locked, messages read/create only
       Future: Add memberUIDs-based read restriction
    ========================== */

    match /chats/{chatId} {

      allow read: if
        loggedIn();

      allow create: if
        loggedIn() &&
        validList(request.resource.data.memberUIDs);

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent chat deletion */
      allow delete: if false;

      /* ---------- MESSAGES ---------- */

      match /messages/{messageId} {

        allow read: if
          loggedIn();

        allow create: if
          loggedIn() &&
          validString(request.resource.data.senderId) &&
          validString(request.resource.data.text);

        /* 🔒 SAFE HARDENING: Messages immutable */
        allow update: if false;

        /* 🔒 SAFE HARDENING: Prevent message deletion */
        allow delete: if false;
      }

      /* ---------- TYPING ---------- */

      match /typing/{uid} {

        allow read: if
          loggedIn();

        allow write: if
          loggedIn();
      }
    }

    /* =========================
       ONLINE STATUS
       Document ID: phone number
       Safe: Keep current model
    ========================== */

    match /status/{uid} {

      allow read: if
        loggedIn();

      allow write: if
        loggedIn();
    }

    /* =========================
       MOVIE TICKETS
       Safe: Keep current model with hardened updates
    ========================== */

    match /movieTickets/{ticketId} {

      allow read: if
        loggedIn();

      allow create: if
        loggedIn();

      allow update: if false;

      allow delete: if false;
    }

    /* =========================
       TICKET REQUESTS
       Safe: Keep current model
    ========================== */

    match /ticketRequests/{requestId} {

      allow read: if
        loggedIn();

      allow create: if
        loggedIn();

      allow update: if false;

      allow delete: if false;
    }

    /* =========================
       COLLABORATORS
       Business partnership requests
       Create: Any logged-in user can submit
       Read: Any logged-in user
       Update: Admin via dashboard
       Delete: Locked
    ========================== */

    match /collaborators/{docId} {

      allow read: if
        loggedIn();

      allow create: if
        loggedIn() &&
        validString(request.resource.data.category) &&
        validString(request.resource.data.subcategory) &&
        validString(request.resource.data.option) &&
        validString(request.resource.data.state) &&
        validString(request.resource.data.district) &&
        validString(request.resource.data.city) &&
        validString(request.resource.data.phone) &&
        (
          request.resource.data.status == "pending" ||
          request.resource.data.status == "approved" ||
          request.resource.data.status == "rejected" ||
          request.resource.data.status == "featured" ||
          request.resource.data.status == "hidden"
        );

      allow update: if
        loggedIn();

      /* 🔒 SAFE HARDENING: Prevent deletion */
      allow delete: if false;
    }

    /* =========================
       REPORTS COLLECTION
       Safe: Create only, admin reads via console
    ========================== */

    match /reports/{docId} {

      allow read: if false;

      allow create: if
        loggedIn();

      allow update: if false;

      allow delete: if false;
    }

    /* =========================
       FALLBACK: DENY ALL UNMATCHED COLLECTIONS
    ========================== */

    match /{document=**} {

      allow read, write: if false;
    }
  }
}