rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    // Check if the request is from the admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'sathyamanojbiyyapu@gmail.com';
    }

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the user's phone from auth
    function getUserPhone() {
      return request.auth.uid;
    }

    // =============================================
    // USERS
    // =============================================

    match /users/{phone} {
      allow read: if true;  // Anyone can read profiles
      allow create: if isAuthenticated() && request.auth.uid == phone;
      allow update: if isAuthenticated() && (
        request.auth.uid == phone ||  // Own profile
        isAdmin()                       // Admin can update any
      );
      allow delete: if isAdmin();
    }

    // =============================================
    // MARKETPLACE - City-based business directories
    // Structure: marketplace/{categorySlug}/states/{state}/districts/{district}/cities/{city}/businesses/{businessId}
    // =============================================

    match /marketplace/{categorySlug}/states/{state}/districts/{district}/cities/{city}/businesses/{businessId} {
      allow read: if true;  // Anyone can see businesses
      allow create: if isAdmin();  // Only admin can create (via approval)
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================
    // PENDING BUSINESSES - User-submitted businesses waiting for approval
    // =============================================

    match /pendingBusinesses/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();  // Any logged-in user can submit
      allow update: if isAdmin();  // Only admin can approve/reject
      allow delete: if isAdmin();
    }

    // =============================================
    // GROUPS
    // =============================================

    match /groups/{groupId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // MATCH REQUESTS
    // =============================================

    match /matchRequests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // CHATS
    // =============================================

    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // MESSAGES subcollection
    // =============================================

    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // =============================================
    // PAYMENTS
    // =============================================

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================
    // SELECTIONS
    // =============================================

    match /selections/{selectionId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // =============================================
    // COLLABORATORS (legacy - kept for existing data)
    // =============================================

    match /collaborators/{collaboratorId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // GYM SUBMISSIONS (legacy - kept for existing data)
    // =============================================

    match /gymSubmissions/{submissionId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =============================================
    // NOTIFICATIONS
    // =============================================

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // =============================================
    // SPOTLIGHT
    // =============================================

    match /spotlight/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =============================================
    // DEFAULT - Deny everything else
    // =============================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}